# ─────────────────────────────────────────────────────────────────────────────
# Railway environment variables — copy to Railway dashboard > Variables
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50

# Hosts & CORS
# Set ALLOWED_HOSTS to your Railway backend domain (no https://)
ALLOWED_HOSTS=your-backend.up.railway.app
# Set CORS_ORIGINS to your Railway frontend URL (with https://)
CORS_ORIGINS=https://your-frontend.up.railway.app

# PostgreSQL — Railway provides these automatically when you add a Postgres plugin
# PGHOST=...
# PGPORT=5432
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=...

# Redis — Railway provides REDIS_URL automatically when you add a Redis plugin
# REDIS_URL=redis://...

# Stripe (leave empty if not needed yet)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio SMS (leave empty to skip SMS sending)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Demo mode: set to true to bypass Stripe and auto-activate candles
DEMO_MODE=true

# ─────────────────────────────────────────────────────────────────────────────
# Railway Services setup (manual via dashboard):
#
# 1. "backend"  — root dir: /backend, Dockerfile detected automatically
#                 Add PostgreSQL + Redis plugins to this service
#
# 2. "frontend" — root dir: /frontend, Dockerfile detected automatically
#                 Set build var: VITE_API_BASE_URL=https://your-backend.up.railway.app
#
# 3. "worker"   — same repo, root /backend, start command:
#                 celery -A config.celery_app worker -l info
#
# 4. "beat"     — same repo, root /backend, start command:
#                 celery -A config.celery_app beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler
#
# 5. "cron-candles" — Cron Job service, schedule: 0 */12 * * *
#                     command: python manage.py seed_candles_random --count 100
# ─────────────────────────────────────────────────────────────────────────────
